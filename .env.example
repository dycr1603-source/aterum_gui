NODE_ENV=production
PORT=3001

# Database
DB_HOST=localhost
DB_USER=tradingbot
DB_PASSWORD=change_me
DB_NAME=trading_bot
DB_CONNECTION_LIMIT=10
DB_TIMEZONE=+00:00

# Auth
SESSION_SECRET=change_me_to_a_long_random_secret
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=change_me_after_first_login

# Binance account read/trade endpoints used by the dashboard
BINANCE_API_KEY=change_me
BINANCE_API_SECRET=change_me

# OpenAI assistant
OPENAI_API_KEY=change_me
OPENAI_ASSISTANT_MODEL=gpt-5-mini

# n8n simulator source
N8N_SQLITE_DB=/home/n8n/.n8n/database.sqlite
N8N_TRADING_WORKFLOW_ID=Cz4TfvaVAygWGRJm

# Local runtime data
TRADES_FILE=./trades.json
